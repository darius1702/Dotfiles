{
  "layer": "bottom",
  "position": "top",
  "spacing": 7,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/notification-pad", "clock", "custom/notification"],
  "modules-right": ["group/media", "network", "group/battery-with-tray"],

  "hyprland/workspaces": {
    // "format": "´æä ",
    "persistent-workspaces": {
      "HDMI-A-1": [ 1, 2, 3, 4 ],
      "DP-1": [ 5, 6, 7 ],
      "eDP-1": [ 8, 9, 10 ]
    }
  },

  "hyprland/submap": {
    "format": "  ¾░îÄ ",
    "on-click": "hyprctl dispatch submap reset"
  },

  "group/clock-and-notifications": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 250,
      "transition-left-to-right": false
    },
    "modules": [
      "clock",
      "custom/notification"
    ]
  },

  "group/battery-with-tray": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 250,
      "transition-left-to-right": false
    },
    "modules": [
      "battery",
      "bluetooth",
      "tray"
    ]
  },

  "group/media": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 250,
      "transition-left-to-right": false
    },
    "modules": [
      "wireplumber",
      "mpris"
    ]
  },

  "mpris": {
    "format": "{status_icon}",
    "status-icons": {
	  "paused": "¾░Éè",
	  "playing": "¾░Åñ"
	},
    "on-click-right" : "",
    "on-click-middle" : "",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+ -l 1.2",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- -l 1.2",
    "tooltip" : false
  },

  "wireplumber": {
    "format": "¾░ò¥",
    "format-muted": "¾░Øƒ",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pwvucontrol",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+ -l 1.2",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- -l 1.2",
    "tooltip-format": "{volume}%\n{node_name}"
  },

  "backlight": {
    "format": "¯®í {percent}%",
    "on-scroll-up": "brightnessctl set 1000+",
    "on-scroll-down": "brightnessctl set 1000-",
    "tooltip": false
  },

  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "¯¢ä",
    "format-disconnected": "¾░ñ½",
    "format-linked": "¾░ñ®",
    "format-disabled": "¾░ñ«",
    "format-icons" : ["¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
    "tooltip-format": "{ipaddr}\n{essid}",
    "on-click": "iwgtk"
  },

  "bluetooth": {
    "format-on": "¾░é»",
    "format-connected": "¾░é»",
    "format-off": "¾░é▓",
    "format-no-controller": "¾░é▓",
    "format-disabled": "¾░é▓",
    "on-click": "blueman-manager",
    "tooltip": true,
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} connected"
  },

  "battery": {
    "bat": "BAT0",
    "adapter": "ADP0",
    "interval": 10,
    "states": {
      "100": 100,
      "90": 90,
      "80": 80,
      "70": 70,
      "60": 60,
      "50": 50,
      "40": 40,
      "30": 30,
      "20": 20,
      "15": 15,
      "10": 10
    },
    "format": "{capacity}",
    "format-charging": "{capacity}¾▒Éï",
    "format-full": "¾▒Éï",
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M  ¯«è  %a %d %b}",
    "tooltip": false,
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw"
  },

  "tray": {
    "icon-size": 15,
    "spacing": 10
  },

  // "custom/emacs-pomm": {
  //   "hide-empty-text": true,
  //   "tooltip": false,
  //   "interval": 5,
  //   "exec-if": "emacsclient -a false -e 't'",
  //   "exec": "emacsclient --eval \"(if (boundp 'pomm-current-mode-line-string) pomm-current-mode-line-string)\" | xargs echo -e"
  // },

  "custom/notification": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "´æä ",
      "none": "",
      "dnd-notification": "´æä ",
      "dnd-none": "´ôâ ",
      "inhibited-notification": "´æä ",
      "inhibited-none": "´ôâ ",
      "dnd-inhibited-notification": "´æä ",
      "dnd-inhibited-none": "´ôâ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  // pad the clock to the left if there is a new notification
  // so the indicator doesn't make the clock jump left
  // ugly hack but the jumping is super annoying
  "custom/notification-pad": {
    "exec": "swaync-client -swb",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "notification": "´æä ",
      "none": "",
      "dnd-notification": "´æä ",
      "dnd-none": "´ôâ ",
      "inhibited-notification": "´æä ",
      "inhibited-none": "´ôâ ",
      "dnd-inhibited-notification": "´æä ",
      "dnd-inhibited-none": "´ôâ "
    },
    "tooltip": false,
    "on-click": ""
  }
}
